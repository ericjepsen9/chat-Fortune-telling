# ============ 缘合 AI 测试环境配置 ============

# Cherry Studio 本地 API 地址
# 默认: http://127.0.0.1:8080/v1
# 如果你用的是 Ollama 直连: http://127.0.0.1:11434/v1
LLM_BASE_URL=http://127.0.0.1:8080/v1

# API Key（Cherry Studio 自定义的 key，或 Ollama 不需要 key 填 ollama）
LLM_API_KEY=your-api-key

# 模型名称（根据你 Cherry Studio 里配置的模型填写）
# 本地 Ollama DeepSeek: deepseek-r1:1.5b 或 deepseek-r1:7b
# 本地 Ollama Qwen: qwen2.5:7b 或 qwq:32b
# 云端 API: gpt-4o-mini / deepseek-chat / qwen-plus
LLM_MODEL=deepseek-r1:1.5b

# 测试服务器端口
SERVER_PORT=3000
