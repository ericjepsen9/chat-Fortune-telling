# 缘合 YuanHe — 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============ 必填 ============
# LLM API 配置
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=MiniMax-M2.7
LLM_API_KEY=your_api_key_here

# JWT 密钥（务必设置固定值，否则每次重启所有用户需重新登录）
JWT_SECRET=your_random_secret_at_least_32_chars

# 管理员 JWT 密钥（可选，默认基于JWT_SECRET派生）
# ADMIN_JWT_SECRET=your_admin_secret_here

# ============ 可选 ============
# 服务端口
PORT=3000

# 运行模式
NODE_ENV=production

# SMS 短信服务（mock=开发模式免验证码）
SMS_PROVIDER=mock
# SMS_ACCESS_KEY=your_sms_key
# SMS_SECRET=your_sms_secret
# SMS_SIGN_NAME=缘合

# CORS 允许的域名（逗号分隔，默认*）
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 备用 LLM Provider
# LLM_BACKUP_URL=https://api.openai.com/v1
# LLM_BACKUP_KEY=sk-xxx
# LLM_BACKUP_MODEL=gpt-4o-mini

# ============ 其他可选模型 ============
# LLM_MODEL=deepseek-ai/DeepSeek-V3          （便宜·效果极好）
# LLM_MODEL=deepseek-ai/DeepSeek-R1          （思维链·最强）
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct       （大模型·中文最强）
