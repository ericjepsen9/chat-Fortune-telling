# ============ 缘合 AI 测试环境配置 ============

# 硅基流动 SiliconFlow API
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=在这里填你的硅基流动API Key
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# 测试服务器端口
SERVER_PORT=3000

# ============ 其他可选模型（免费） ============
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct        （免费·推荐·中文好）
# LLM_MODEL=THUDM/glm-4-9b-chat              （免费·中文好）
# LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct  （免费·英文好）
#
# ============ 付费模型（效果更好） ============
# LLM_MODEL=deepseek-ai/DeepSeek-V3          （便宜·效果极好）
# LLM_MODEL=deepseek-ai/DeepSeek-R1          （思维链·最强）
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct       （大模型·中文最强）
